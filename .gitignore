# =============================================================================
# OpenMythos — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python bytecode & caches
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python

# -----------------------------------------------------------------------------
# Distribution / packaging
# -----------------------------------------------------------------------------
build/
dist/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.spec

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.env
.envrc
.venv/
env/
venv/
ENV/
env.bak/
venv.bak/
venv-mythos/
.pixi/
__pypackages__/

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
.cache
htmlcov/
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/

# -----------------------------------------------------------------------------
# Jupyter / IPython
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
profile_default/
ipython_config.py

# -----------------------------------------------------------------------------
# Experiment results — large binary files, not for version control
# Figures and JSON summaries ARE committed (small, useful for paper)
# -----------------------------------------------------------------------------

# PyTorch checkpoint files (can be hundreds of MB)
results/**/*.pt
results_overnight/**/*.pt
results_gpu/**/*.pt

# Checkpoint directories (keep the dirs via .gitkeep, not the .pt files)
results/checkpoints_*/
results_overnight/checkpoints_*/
results_gpu/checkpoints_*/

# Temporary test checkpoints
results/test_ckpt/

# HuggingFace dataset cache
~/.cache/huggingface/
.cache/

# -----------------------------------------------------------------------------
# Keep these result files (small, needed for paper figures & reproducibility)
# -----------------------------------------------------------------------------
# results/run_*.json          ← kept (small JSON, paper tables)
# results/halt_log_*.jsonl    ← kept (small JSONL, paper figures)
# results/figures/            ← kept (PNG figures for paper)
# results/difficulty_validation.pt is small but binary — exclude anyway
results/difficulty_validation.pt
results/act_scores.pt
results/halt_depths.pt
results_overnight/difficulty_validation.pt
results_overnight/act_scores.pt
results_overnight/halt_depths.pt
results_gpu/difficulty_validation.pt
results_gpu/act_scores.pt
results_gpu/halt_depths.pt

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
pip-log.txt
pip-delete-this-directory.txt

# -----------------------------------------------------------------------------
# OS-specific
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDE / editor
# -----------------------------------------------------------------------------
.idea/
*.iml
*.iws
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# Type checkers & linters
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
cython_debug/

# -----------------------------------------------------------------------------
# Build tools
# -----------------------------------------------------------------------------
.pybuilder/
target/
.pdm-python
.pdm-build/

# -----------------------------------------------------------------------------
# Docs build output
# -----------------------------------------------------------------------------
docs/_build/
/site

# -----------------------------------------------------------------------------
# Secrets & local config
# -----------------------------------------------------------------------------
.env.local
.env.*.local
secrets.py
local_settings.py
*.pem
*.key

# -----------------------------------------------------------------------------
# Kiro IDE (keep specs, ignore generated/cache files)
# -----------------------------------------------------------------------------
.kiro/settings/
.kiro/hooks/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.abstra/
.cursorignore
.cursorindexingignore
marimo/_static/
marimo/_lsp/
__marimo__/
.pypirc
celerybeat-schedule
celerybeat.pid
*.sage.py
*.mo
*.pot
db.sqlite3
db.sqlite3-journal
